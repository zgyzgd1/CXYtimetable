<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_today_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 顶部日期栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/widget_today_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@id/widget_today_add_btn"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_today_add_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_add_course"
            android:gravity="center"
            android:text="@string/widget_add_symbol"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />
    </RelativeLayout>

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/widget_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:textColor="#B0B0B0"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- 课程列表 -->
    <LinearLayout
        android:id="@+id/widget_course_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 课程项1 -->
        <LinearLayout
            android:id="@+id/widget_course_item_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_course_item_bg"
            android:orientation="horizontal"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/widget_course_dot_1"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="12dp"
                android:importantForAccessibility="no"
                android:src="@drawable/widget_course_dot" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_course_title_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_course_title_active"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_course_time_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/widget_course_time_active"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 课程项2 -->
        <LinearLayout
            android:id="@+id/widget_course_item_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_course_item_bg"
            android:orientation="horizontal"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/widget_course_dot_2"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="12dp"
                android:importantForAccessibility="no"
                android:src="@drawable/widget_course_dot" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_course_title_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_course_title_active"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_course_time_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/widget_course_time_active"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 课程项3 -->
        <LinearLayout
            android:id="@+id/widget_course_item_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_course_item_bg"
            android:orientation="horizontal"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/widget_course_dot_3"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="12dp"
                android:importantForAccessibility="no"
                android:src="@drawable/widget_course_dot" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_course_title_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_course_title_active"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_course_time_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/widget_course_time_active"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 课程项4 -->
        <LinearLayout
            android:id="@+id/widget_course_item_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_course_item_bg"
            android:orientation="horizontal"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/widget_course_dot_4"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="12dp"
                android:importantForAccessibility="no"
                android:src="@drawable/widget_course_dot" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_course_title_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_course_title_active"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_course_time_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/widget_course_time_active"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
